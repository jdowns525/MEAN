<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <link rel="stylesheet" href="/css/style.css" type="text/css">
</head>
<body>

  {{> header}}

  <div id="contents">
    <div class="box">
      <div>
        <div class="body">
          <h1>{{title}}</h1>
          <ul id="sites">
            {{#each trips}}
              <li>
                <img src="{{this.image}}" alt="{{this.name}}">
                <h2>{{this.name}}</h2>
                <p>{{this.description1}}</p>
                <p>{{this.description2}}</p>
              </li>
            {{/each}}
          </ul>
        </div>
      </div>
    </div>
  </div>

  {{> footer}}

</body>
</html>

