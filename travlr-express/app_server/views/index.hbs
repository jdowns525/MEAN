<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{{title}}</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <header>
      <h1>{{title}}</h1>
      <p>{{tagline}}</p>
    </header>

    <main>
      <h2>Available Trips</h2>
      <ul>
        {{#each trips}}
          <li>
            <h3>{{title}}</h3>
            <p>{{description}}</p>
            <p><strong>Price: {{price}}</strong></p>
          </li>
        {{/each}}
      </ul>
    </main>
  </body>
</html>
